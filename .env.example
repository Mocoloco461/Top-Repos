# PostgreSQL Database Credentials
POSTGRES_USER="your_postgres_username"
POSTGRES_PASSWORD="your_secure_postgres_password"
POSTGRES_DB="top_repos"

# PostgreSQL Database Connection URL (for local development outside Docker)
DATABASE_URL="postgresql://your_postgres_username:your_secure_postgres_password@localhost:5432/top_repos?schema=public"

# Secret 32-byte hex key for AES-256-GCM encryption (64 hex characters)
ENCRYPTION_KEY="your_64_char_hex_encryption_key_here"

# Application Port
PORT=3000
